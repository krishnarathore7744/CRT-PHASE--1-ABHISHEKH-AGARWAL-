// Program 1 
// Makking of 2D array
#include <iostream>
using namespace std;

int main() {
    int arr[3][3];
    
    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            cin >> arr[i][j];
        }
    }
    
    cout <<"here is your 2 day array" << "\n";
    for(int i = 0; i < 3;  i++) {
        for (int j = 0; j < 3; j++) {
            cout << arr[i][j] << " ";
        }
        cout << "\n";
    }
    return 0;
}

// Program 2 
// Sum of elements of 2D array
#include <iostream>
using namespace std;

int main() {
    int arr[2][2];
    int sum = 0;
    for(int i = 0; i < 2; i++) {
        for(int j = 0; j < 2; j++) {
            cin >> arr[i][j];
            sum = sum + arr[i][j];
        }
    }
    cout << sum;
}

    

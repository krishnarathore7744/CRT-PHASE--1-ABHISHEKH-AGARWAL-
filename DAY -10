// Search an element in 2D matrix

#include <iostream>
using namespace std;

int main() {
    int arr[2][2] = { {10,20},
                    {30,40} };
                    
    int searchElement;
    cin >> searchElement;
    
    for(int i = 0; i < 2; i++) {
        for(int j = 0; j < 2; j++) {
            if(arr[i][j] == searchElement) {
                cout << i << " " << j;
                }
            }
        }
    cout << "element not found...";
}   

// proble 4 leetcode que.2
class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        for(int i = 0; i < nums.size(); i++) {
            for(int j = i + 1; j < nums.size(); j++) {
                if(nums[i] + nums[j] == target) {
                    return {i,j};
                }
            }
        }
        return {};
    }
};
